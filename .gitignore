# MeddyNet Monorepo — Root Gitignore

# Environment files (CRITICAL — never commit secrets)
.env
.env.local
.env.production
.env.staging

# Dependencies
node_modules/
__pycache__/
*.pyc
.pyo
*.egg-info/
dist/
build/

# Next.js
.next/
out/

# Python virtual environments
venv/
.venv/
env/

# IDE
.vscode/settings.json
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db
nul

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test coverage
coverage/
htmlcov/
.pytest_cache/

# Build artifacts
*.tsbuildinfo
next-env.d.ts

# Database
*.db
*.sqlite3

# Misc
*.pem
.vercel

# Executables
*.exe
