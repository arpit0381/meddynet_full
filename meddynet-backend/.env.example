# ═══════════════════════════════════════════════════════════
# MeddyNet Backend — Environment Variables
# Copy this file to `.env` and fill in all required values.
# ═══════════════════════════════════════════════════════════

# ─── Core ───
ENVIRONMENT=development
SECRET_KEY=your-secret-key-here

# ─── Database (PostgreSQL via Neon/Supabase) ───
DATABASE_URL=postgresql+asyncpg://user:pass@host/db?sslmode=require
NEON_DATABASE_URL=

# ─── Supabase ───
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=
SUPABASE_JWT_SECRET=

# ─── JWT ───
JWT_SECRET_KEY=
FERNET_KEY=

# ─── Razorpay (Payments) ───
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAYX_ACCOUNT_NUMBER=

# ─── Redis (Rate Limiting, OTP, Celery) ───
REDIS_URL=redis://user:pass@host:port
UPSTASH_REDIS_URL=

# ─── MongoDB (Analytics, Notifications, Logs) ───
MONGODB_URL=
MONGODB_DB_NAME=meddynet_analytics

# ─── Cloudinary (Legacy — may be replaced by Supabase Storage) ───
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── SMS/OTP Providers ───
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
AUTHKEY_API_KEY=
AUTHKEY_SENDER_ID=MEDDYN

# ─── WhatsApp Business API ───
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ─── CORS & Security ───
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003
ALLOWED_ADMIN_IPS=

# ─── Portal Discovery URLs ───
LAB_PORTAL_URL=http://localhost:3001
ADMIN_PORTAL_URL=http://localhost:3002
TECHNICIAN_PORTAL_URL=http://localhost:3003
PATIENT_PORTAL_URL=http://localhost:3000
